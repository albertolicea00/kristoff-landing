---
import Layout from '../layouts/Layout.astro';

const projects = [
  {
    title: 'Rancho Kristoff',
    description: 'Ranking interactivo de provincias cubanas con mapa en vivo y votación en tiempo real.',
    longDescription: 'Mapa interactivo de Cuba donde los fans votan por su provincia. Ranking en tiempo real con 261K+ votos, mapa SVG animado con colores dinámicos por posición, sistema de leaderboard y estadísticas por provincia. Las votaciones se actualizan en vivo durante los streams.',
    status: 'Activo',
    statusColor: 'bg-green-500',
    icon: '🇨🇺',
    tags: ['Mapa', 'Ranking', 'Votación', 'En Vivo', 'Cuba'],
    tech: ['Firebase', 'SVG', 'JavaScript'],
    url: 'https://ranchokristoff.web.app/',
    github: '#',
    image: 'https://images.unsplash.com/photo-1524661135-423995f22d0b?w=800&q=80'
  },
  {
    title: 'Tortilla TV',
    description: 'Video chat aleatorio para la comunidad de Kristoff, estilo Omegle pero cubano.',
    longDescription: 'Plataforma de video chat aleatorio donde los fans se conectan 1v1 en tiempo real. Incluye un modo especial "Modo Kristoff" con salas de 3 personas donde Kristoff hace de host. Chat directo, limpio y con la energía de la comunidad cubana.',
    status: 'Activo',
    statusColor: 'bg-green-500',
    icon: '📺',
    tags: ['Video Chat', '1v1', 'Comunidad', 'Live', 'WebRTC'],
    tech: ['WebRTC', 'JavaScript', 'Firebase'],
    url: 'https://www.tortillatv.com/',
    github: '#',
    image: 'https://images.unsplash.com/photo-1611162617474-5b21e879e113?w=800&q=80'
  },
  {
    title: 'Kristoff Trivia',
    description: '¿Cuánto sabes de Kristoff? Quiz interactivo con preguntas sobre sus videos, frases y momentos épicos.',
    longDescription: 'Juego de trivia con múltiples categorías: frases de Kristoff, momentos del podcast, referencias culturales cubanas, y datos sobre Miami. Sistema de puntuación, leaderboard global y logros desbloqueables.',
    status: 'Próximamente',
    statusColor: 'bg-blue-500',
    icon: '🧠',
    tags: ['Juego', 'Trivia', 'Interactivo', 'Leaderboard'],
    tech: ['Svelte', 'Supabase', 'Animaciones'],
    url: '#',
    github: '#',
    image: 'https://images.unsplash.com/photo-1606326608606-aa0b62935f2b?w=800&q=80'
  },
  {
    title: 'Clip Machine',
    description: 'Herramienta para recortar y compartir los mejores momentos de los streams y videos de Kristoff.',
    longDescription: 'Permite a los fans crear clips cortos desde los videos de YouTube y streams de Twitch. Editor simple con recorte, subtítulos automáticos y exportación optimizada para redes sociales. Los mejores clips se muestran en la web oficial.',
    status: 'Idea',
    statusColor: 'bg-gray-500',
    icon: '✂️',
    tags: ['Videos', 'Clips', 'Editor', 'Viral'],
    tech: ['FFmpeg.wasm', 'React', 'YouTube API'],
    url: '#',
    github: '#',
    image: 'https://images.unsplash.com/photo-1574717024653-61fd2cf4d44d?w=800&q=80'
  },
  {
    title: 'Soundboard Kriollo',
    description: 'Las frases más famosas de Kristoff en un soundboard interactivo. Perfecto pa\' los grupos de WhatsApp.',
    longDescription: 'Soundboard web con las frases más icónicas de Kristoff organizadas por categorías. Cada sonido tiene botón de compartir por WhatsApp, descarga directa y opción de crear combos de sonidos. La comunidad puede sugerir nuevos clips.',
    status: 'Idea',
    statusColor: 'bg-gray-500',
    icon: '🔊',
    tags: ['Audio', 'Soundboard', 'Viral', 'WhatsApp'],
    tech: ['Vanilla JS', 'Web Audio API'],
    url: '#',
    github: '#',
    image: 'https://images.unsplash.com/photo-1598488035139-bdbb2231ce04?w=800&q=80'
  }
];
---

<Layout title="Proyectos de la Comunidad | Kristoff Kriollo">
  <div class="min-h-screen bg-background pt-28 pb-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      
      <!-- Header -->
      <div class="text-center mb-16">
        <h1 class="text-4xl md:text-7xl font-heading text-primary uppercase tracking-widest mb-4">
          Proyectos
        </h1>
        <p class="font-body text-xl text-gray-500 max-w-2xl mx-auto">
          Apps y herramientas creadas por y para la comunidad de Kristoff Kriollo.
        </p>
        <a href="/developers" class="inline-flex items-center gap-2 mt-4 font-heading text-lg uppercase tracking-wider text-primary hover:text-red-600 transition-colors">
          🛠️ ¿Eres developer? Únete al equipo →
        </a>
      </div>

      <!-- Projects Grid -->
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {projects.map((project) => (
          <div class="bg-white border border-gray-100 rounded-2xl overflow-hidden shadow-md hover:shadow-2xl transition-all duration-300 transform hover:-translate-y-2 flex flex-col group">
            
            <!-- Image Header -->
            <div class="relative h-48 w-full bg-gray-900 overflow-hidden">
              <img 
                src={project.image} 
                alt={project.title} 
                class="w-full h-full object-cover opacity-80 group-hover:opacity-100 group-hover:scale-110 transition-all duration-500"
                loading="lazy"
              />
              <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-transparent to-transparent"></div>
              
              <div class="absolute top-4 right-4">
                <span class={`${project.statusColor} text-white font-heading text-[10px] uppercase tracking-wider px-3 py-1 rounded-full shadow-lg`}>
                  {project.status}
                </span>
              </div>
            </div>
            
            <div class="p-8 flex flex-col flex-1">
              <!-- Header -->
              <div class="flex items-start justify-between mb-4">
                <span class="text-5xl">{project.icon}</span>
              </div>

              <!-- Title -->
              <h2 class="font-heading text-3xl text-secondary uppercase tracking-wide mb-3 group-hover:text-primary transition-colors">
                {project.title}
              </h2>
              
              <!-- Description -->
              <p class="font-body text-gray-600 text-sm leading-relaxed mb-4">
                {project.longDescription}
              </p>

              <!-- Tech Stack -->
              <div class="mb-4">
                <span class="font-heading text-xs text-gray-400 uppercase tracking-wider">Tech Stack:</span>
                <div class="flex flex-wrap gap-1.5 mt-1">
                  {project.tech.map((t) => (
                    <span class="bg-secondary text-white font-body text-xs px-2 py-0.5 rounded">{t}</span>
                  ))}
                </div>
              </div>

              <!-- Tags -->
              <div class="flex flex-wrap gap-1.5 mb-6">
                {project.tags.map((tag) => (
                  <span class="bg-gray-100 text-gray-500 font-body text-xs px-2 py-0.5 rounded">{tag}</span>
                ))}
              </div>

              <!-- CTAs -->
              <div class="mt-auto flex gap-2">
                {project.url !== '#' ? (
                  <a href={project.url} target="_blank" class="flex-1 bg-primary hover:bg-red-600 text-white font-heading text-sm uppercase tracking-wider py-3 rounded-xl text-center transition-colors">
                    Ver App
                  </a>
                ) : (
                  <div class="flex-1 bg-gray-100 text-gray-400 font-heading text-sm uppercase tracking-wider py-3 rounded-xl text-center cursor-default">
                    Próximamente
                  </div>
                )}
                {project.github !== '#' ? (
                  <a href={project.github} target="_blank" class="bg-secondary hover:bg-gray-800 text-white font-heading text-sm uppercase tracking-wider px-4 py-3 rounded-xl text-center transition-colors flex items-center gap-1">
                    <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
                    GitHub
                  </a>
                ) : null}
              </div>
            </div>
          </div>
        ))}
      </div>

      <!-- CTA -->
      <div class="text-center mt-16 bg-secondary rounded-2xl p-12 border-2 border-primary">
        <h3 class="font-heading text-3xl md:text-4xl text-white uppercase tracking-wide mb-4">
          ¿Tienes una idea para un proyecto?
        </h3>
        <p class="font-body text-gray-400 mb-8 max-w-xl mx-auto">
          Si eres developer y quieres crear algo para la comunidad, te damos un subdominio oficial y te promocionamos. 
        </p>
        <a href="/developers" class="btn-primary inline-flex items-center gap-2">
          🛠️ Más información para developers
        </a>
      </div>

    </div>
  </div>
</Layout>
