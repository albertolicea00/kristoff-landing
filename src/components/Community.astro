---
import { getLangFromUrl, useTranslations } from '../i18n/utils';
import { getSocialStats, getTwitchStatus } from '../utils/social';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const stats = await getSocialStats();
const twitchLive = await getTwitchStatus();
---

<section id="community" class="py-24 bg-accent relative border-y-8 border-secondary">
  <div class="absolute inset-0 opacity-10" style="background-image: radial-gradient(#111 2px, transparent 2px); background-size: 30px 30px;"></div>
  
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10 text-center">
    <h2 class="text-6xl md:text-8xl font-heading text-secondary uppercase tracking-widest mb-16 drop-shadow-sm">
      {t('community.title')}
    </h2>
    
    <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-4 md:gap-6 mb-16">
      
      <a href="https://www.instagram.com/kristoff_kriollo/" target="_blank" rel="noopener noreferrer" class="block bg-secondary text-white p-6 md:p-8 rounded-2xl transform hover:scale-105 transition-all shadow-[6px_6px_0_0_rgba(255,59,59,1)] hover:shadow-[10px_10px_0_0_rgba(255,59,59,1)]">
        <h3 class="font-heading text-3xl md:text-4xl text-pink-500 mb-2">{stats.instagram}</h3>
        <p class="font-body text-xs uppercase tracking-wider text-gray-400 flex items-center justify-center gap-1">
          <svg class="w-3.5 h-3.5 text-pink-500" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line></svg>
          Instagram
        </p>
      </a>

      <!-- YouTube Subs -->
      <a href="https://www.youtube.com/@Kristoff9" target="_blank" rel="noopener noreferrer" class="block bg-secondary text-white p-6 md:p-8 rounded-2xl transform hover:scale-105 transition-all shadow-[6px_6px_0_0_rgba(255,59,59,1)] hover:shadow-[10px_10px_0_0_rgba(255,59,59,1)]">
        <h3 class="font-heading text-3xl md:text-4xl text-primary mb-2">{stats.youtube}</h3>
        <p class="font-body text-xs uppercase tracking-wider text-gray-400 flex items-center justify-center gap-1">
          <svg class="w-3.5 h-3.5 text-primary" fill="currentColor" viewBox="0 0 24 24"><path fill-rule="evenodd" d="M19.812 5.418c.861.23 1.538.907 1.768 1.768C21.998 8.746 22 12 22 12s0 3.255-.418 4.814a2.504 2.504 0 0 1-1.768 1.768c-1.56.419-7.814.419-7.814.419s-6.255 0-7.814-.419a2.505 2.505 0 0 1-1.768-1.768C2 15.255 2 12 2 12s0-3.255.417-4.814a2.507 2.507 0 0 1 1.768-1.768C5.744 5 11.998 5 11.998 5s6.255 0 7.814.418ZM15.194 12 10 15V9l5.194 3Z" clip-rule="evenodd" /></svg>
          YouTube
        </p>
      </a>

      <!-- YouTube Views -->
      <a href="https://www.youtube.com/@Kristoff9" target="_blank" rel="noopener noreferrer" class="block bg-secondary text-white p-6 md:p-8 rounded-2xl transform hover:scale-105 transition-all shadow-[6px_6px_0_0_rgba(255,214,0,0.8)] hover:shadow-[10px_10px_0_0_rgba(255,214,0,0.8)]">
        <h3 class="font-heading text-3xl md:text-4xl text-accent mb-2">{stats.youtubeViews}</h3>
        <p class="font-body text-xs uppercase tracking-wider text-gray-400 flex items-center justify-center gap-1">
          👁️ Views
        </p>
      </a>

      <!-- TikTok -->
      <a href="https://www.tiktok.com/@kristoff_y" target="_blank" rel="noopener noreferrer" class="block bg-secondary text-white p-6 md:p-8 rounded-2xl transform hover:scale-105 transition-all shadow-[6px_6px_0_0_rgba(255,59,59,1)] hover:shadow-[10px_10px_0_0_rgba(255,59,59,1)]">
        <h3 class="font-heading text-3xl md:text-4xl text-white mb-2">{stats.tiktok}</h3>
        <p class="font-body text-xs uppercase tracking-wider text-gray-400 flex items-center justify-center gap-1">
          <svg class="w-3.5 h-3.5 text-white" fill="currentColor" viewBox="0 0 448 512"><path d="M448,209.91a210.06,210.06,0,0,1-122.77-39.25V349.38A162.55,162.55,0,1,1,185,188.31V278.2a74.62,74.62,0,1,0,52.23,71.18V0l88,0a121.18,121.18,0,0,0,1.86,22.17h0A122.18,122.18,0,0,0,381,102.39a121.43,121.43,0,0,0,67,20.14Z"/></svg>
          TikTok
        </p>
      </a>

      <!-- Twitch -->
      <a href="https://www.twitch.tv/kristoff_kriollo" target="_blank" rel="noopener noreferrer" class="block bg-secondary text-white p-6 md:p-8 rounded-2xl transform hover:scale-105 transition-all shadow-[6px_6px_0_0_rgba(169,112,255,1)] hover:shadow-[10px_10px_0_0_rgba(169,112,255,1)] relative overflow-hidden">
        {twitchLive ? (
          <div class="absolute top-2 right-2 flex items-center gap-1 bg-red-600 px-2 py-0.5 rounded text-xs font-heading animate-pulse">
            <div class="w-2 h-2 bg-white rounded-full"></div> LIVE
          </div>
        ) : null}
        <h3 class="font-heading text-3xl md:text-4xl text-purple-400 mb-2">{stats.twitch}</h3>
        <p class="font-body text-xs uppercase tracking-wider text-gray-400 flex items-center justify-center gap-1">
          <svg class="w-3.5 h-3.5 text-purple-400" fill="currentColor" viewBox="0 0 24 24"><path d="M11.571 4.714h1.715v5.143H11.57zm4.715 0H18v5.143h-1.714zM6 0L1.714 4.286v15.428h5.143V24l4.286-4.286h3.428L22.286 12V0zm14.571 11.143l-3.428 3.428h-3.429l-3 3v-3H6.857V1.714h13.714Z"/></svg>
          Twitch
        </p>
      </a>

      <!-- Discord -->
      <a href="#" id="discord-link" target="_blank" rel="noopener noreferrer" class="block bg-secondary text-white p-6 md:p-8 rounded-2xl transform hover:scale-105 transition-all shadow-[6px_6px_0_0_rgba(88,101,242,1)] hover:shadow-[10px_10px_0_0_rgba(88,101,242,1)]">
        <h3 class="font-heading text-3xl md:text-4xl text-[#5865F2] mb-2">Discord</h3>
        <p class="font-body text-xs uppercase tracking-wider text-gray-400 flex items-center justify-center gap-1">
          <svg class="w-3.5 h-3.5 text-[#5865F2]" fill="currentColor" viewBox="0 0 24 24"><path d="M20.317 4.3698a19.7913 19.7913 0 00-4.8851-1.5152.0741.0741 0 00-.0785.0371c-.211.3753-.4447.8648-.6083 1.2495-1.8447-.2762-3.68-.2762-5.4868 0-.1636-.3933-.4058-.8742-.6177-1.2495a.077.077 0 00-.0785-.037 19.7363 19.7363 0 00-4.8852 1.515.0699.0699 0 00-.0321.0277C.5334 9.0458-.319 13.5799.0992 18.0578a.0824.0824 0 00.0312.0561c2.0528 1.5076 4.0413 2.4228 5.9929 3.0294a.0777.0777 0 00.0842-.0276c.4616-.6304.8731-1.2952 1.226-1.9942a.076.076 0 00-.0416-.1057c-.6528-.2476-1.2743-.5495-1.8722-.8923a.077.077 0 01-.0076-.1277c.1258-.0943.2517-.1923.3718-.2914a.0743.0743 0 01.0776-.0105c3.9278 1.7933 8.18 1.7933 12.0614 0a.0739.0739 0 01.0785.0095c.1202.099.246.1981.3728.2924a.077.077 0 01-.0066.1276 12.2986 12.2986 0 01-1.873.8914.0766.0766 0 00-.0407.1067c.3604.698.7719 1.3628 1.225 1.9932a.076.076 0 00.0842.0286c1.961-.6067 3.9495-1.5219 6.0023-3.0294a.077.077 0 00.0313-.0552c.5004-5.177-.8382-9.6739-3.5485-13.6604a.061.061 0 00-.0312-.0286z"/></svg>
          Únete
        </p>
      </a>

    </div>

    <!-- Live Counter Element -->
    <div class="inline-flex items-center bg-white px-6 py-3 rounded-full shadow-lg border-2 border-secondary font-heading text-2xl uppercase tracking-wider text-secondary">
      <span class="w-4 h-4 rounded-full bg-primary animate-pulse mr-3"></span>
      {t('cubans_online')} <span id="counter" class="ml-2 font-bold text-primary">0</span>
    </div>
  </div>
</section>

<script>
  // Simulate "cubanos conectados" based on time of day for realistic feeling
  const counterElement = document.getElementById('counter');
  if (counterElement) {
    const hour = new Date().getHours();
    // More people during evening Miami time (7pm-11pm), less at night
    const baseByHour = hour >= 19 && hour <= 23 ? 4200 : hour >= 12 && hour <= 18 ? 2800 : hour >= 7 && hour <= 11 ? 1500 : 800;
    let current = baseByHour + Math.floor(Math.random() * 600);
    counterElement.innerText = current.toLocaleString();
    
    setInterval(() => {
      const change = Math.floor(Math.random() * 11) - 5; // -5 to +5
      current = Math.max(500, current + change);
      counterElement.innerText = current.toLocaleString();
    }, 2500);
  }
</script>
