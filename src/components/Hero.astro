---
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const supabaseUrl = import.meta.env.PUBLIC_SUPABASE_URL || '';
const supabaseKey = import.meta.env.PUBLIC_SUPABASE_ANON_KEY || '';
---

<section id="hero" class="relative min-h-screen flex items-center justify-center pt-20 overflow-hidden bg-secondary" data-sb-url={supabaseUrl} data-sb-key={supabaseKey}>
  <!-- Background Pattern -->
  <div class="absolute inset-0 z-0 opacity-20">
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_center,_var(--tw-gradient-stops))] from-primary/30 to-secondary transform scale-150"></div>
    <div class="w-full h-full bg-[url('https://www.transparenttextures.com/patterns/cubes.png')] animate-pulse"></div>
  </div>

  <!-- Floating Notes Container (populated by JS from Supabase) -->
  <div id="floating-notes" class="absolute inset-0 z-[1] pointer-events-none overflow-hidden"></div>

  <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center flex flex-col items-center">
    <!-- Profile Picture (Instagram) -->
    <div class="w-48 h-48 md:w-64 md:h-64 rounded-full border-4 border-primary overflow-hidden shadow-[0_0_30px_rgba(255,59,59,0.5)] mb-8 transform hover:scale-105 transition-transform duration-300">
      <img 
        src="https://scontent-mia3-1.cdninstagram.com/v/t51.2885-19/313369687_2961448937494548_2550186981144203115_n.jpg?stp=dst-jpg_s150x150_tt6&_nc_cat=109&ccb=1-7&_nc_sid=d3d953&_nc_ohc=8x26P1AEX9IQ7kNvgFWQ8qQ&_nc_zt=24&_nc_ht=scontent-mia3-1.cdninstagram.com&oh=00_AYB7e0Qjix9x6b-VvJ1U5R15L645Tj1i2h9z1i2h9z1i2Q&oe=64E24294" 
        alt="Kristoff Kriollo" 
        class="w-full h-full object-cover"
        loading="eager"
        onerror="this.src='https://yt3.ggpht.com/_nwkuUvKJT-ztrUNH1bymp7trvZfDXp07UVV7NJNv-Zfws0Wpnlla9nExFRhYSVNAMeKxt9AHA=s800-c-k-c0x00ffffff-no-rj'"
      />
    </div>

    <!-- Titles -->
    <h1 class="text-6xl md:text-8xl lg:text-9xl font-heading font-bold text-white mb-4 tracking-wider leading-none">
      KRISTOFF <span class="text-primary block md:inline">KRIOLLO</span>
    </h1>
    
    <h2 class="text-2xl md:text-4xl text-accent font-heading mb-6 rotate-[-2deg] transform">
      {t('hero.title')}
    </h2>
    
    <p class="text-lg md:text-xl text-gray-300 max-w-2xl mx-auto mb-10 font-body">
      {t('hero.subtitle')}
    </p>

    <!-- CTAs -->
    <div class="flex flex-col sm:flex-row space-y-4 sm:space-y-0 sm:space-x-6">
      <a href="#videos" class="btn-primary flex items-center justify-center shadow-[0_0_20px_rgba(255,59,59,0.4)]">
        <svg class="w-6 h-6 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
        {t('hero.cta')}
      </a>
      <a href="#collabs" class="btn-secondary">
        {t('nav.collabs')}
      </a>
    </div>

    <!-- Leave a Note (hidden for now) -->
    <div class="mt-12 w-full max-w-lg hidden">
      <form id="note-form" class="flex flex-col sm:flex-row gap-2">
        <input type="text" id="note-username" placeholder="Tu nombre (opcional)" maxlength="20" class="w-full sm:w-32 px-4 py-3 rounded-full bg-white/10 backdrop-blur-sm border border-white/20 text-white placeholder:text-gray-500 font-body text-sm" />
        <input type="text" id="note-input" placeholder="Deja tu nota aquí..." maxlength="80" class="flex-1 px-4 py-3 rounded-full bg-white/10 backdrop-blur-sm border border-white/20 text-white placeholder:text-gray-400 font-body text-sm" />
        <button type="submit" class="bg-primary text-white font-heading text-sm uppercase px-6 py-3 rounded-full">Enviar</button>
      </form>
    </div>
  </div>

  <!-- Scroll Down Indicator (Visual Only) -->
  <div class="absolute bottom-8 left-1/2 transform -translate-x-1/2 flex flex-col items-center opacity-60 z-20 pointer-events-none">
    <div class="w-6 h-10 border-2 border-white rounded-full flex justify-center p-1 drop-shadow-md">
      <div class="w-1.5 h-3 bg-white rounded-full animate-[bounce_1.5s_infinite]"></div>
    </div>
  </div>

  <!-- Twitch Live Popup -->
  <div id="twitch-popup" class="fixed bottom-6 right-6 z-50 hidden animate-[slideUp_0.5s_ease-out]">
    <div class="bg-purple-900 border-2 border-purple-500 rounded-2xl p-5 shadow-[0_10px_40px_rgba(145,70,255,0.4)] max-w-sm relative">
      <button id="close-twitch-popup" class="absolute -top-2 -right-2 w-7 h-7 bg-gray-800 border border-gray-600 rounded-full text-white flex items-center justify-center text-sm hover:bg-red-600 transition-colors cursor-pointer">✕</button>
      <div class="flex items-center gap-3 mb-3">
        <div class="relative">
          <div class="w-3 h-3 bg-red-500 rounded-full animate-ping absolute"></div>
          <div class="w-3 h-3 bg-red-500 rounded-full relative"></div>
        </div>
        <span class="font-heading text-white text-lg uppercase tracking-wider">En Vivo Ahora</span>
      </div>
      <p class="text-purple-200 font-body text-sm mb-4">¡Kristoff está en directo en Twitch! Entra pa' la locura 🔥</p>
      <a href="https://www.twitch.tv/kristoff_kriollo" target="_blank" class="block w-full bg-purple-600 hover:bg-purple-500 text-white font-heading text-center py-3 rounded-xl uppercase tracking-wider transition-colors active:scale-95">
        <svg class="w-5 h-5 inline mr-2" fill="currentColor" viewBox="0 0 24 24"><path d="M11.571 4.714h1.715v5.143H11.57zm4.715 0H18v5.143h-1.714zM6 0L1.714 4.286v15.428h5.143V24l4.286-4.286h3.428L22.286 12V0zm14.571 11.143l-3.428 3.428h-3.429l-3 3v-3H6.857V1.714h13.714Z"/></svg>
        Ver en Twitch
      </a>
    </div>
  </div>

</section>

<script>
  // ===== TWITCH LIVE POPUP =====
  async function checkTwitchLive() {
    try {
      const res = await fetch('https://gql.twitch.tv/gql', {
        method: 'POST',
        headers: { 'Client-Id': 'kimne78kx3ncx6brgo4mv6wki5h1ko' },
        body: JSON.stringify({
          query: `query { user(login: "kristoff_kriollo") { stream { id type viewersCount } } }`
        })
      });
      const data = await res.json();
      const stream = data?.data?.user?.stream;
      
      if (stream && !sessionStorage.getItem('twitch-popup-closed')) {
        const popup = document.getElementById('twitch-popup');
        if (popup) {
          popup.classList.remove('hidden');
        }
      }
    } catch(e) { /* silent */ }
  }

  const closeBtn = document.getElementById('close-twitch-popup');
  if (closeBtn) {
    closeBtn.addEventListener('click', () => {
      const popup = document.getElementById('twitch-popup');
      if (popup) popup.classList.add('hidden');
      sessionStorage.setItem('twitch-popup-closed', 'true');
    });
  }

  checkTwitchLive();

  // ===== FLOATING NOTES (Supabase) =====
  const heroEl = document.getElementById('hero');
  const SUPABASE_URL = heroEl?.dataset.sbUrl || '';
  const SUPABASE_ANON_KEY = heroEl?.dataset.sbKey || '';

  const isSupabaseConfigured = SUPABASE_URL.length > 10 && SUPABASE_ANON_KEY.length > 10;

  const demoNotes = [
    { text: 'Kristoff el mejor 🇨🇺🔥', username: 'ElCubano' },
    { text: 'Miami se siente 🌴', username: null },
    { text: 'El contenido más real del internet', username: 'LaFlaca305' },
    { text: 'Asere qué bolá!!!', username: null },
    { text: 'Desde La Habana con amor ❤️', username: 'Yoandy' },
    { text: 'La 826 me tiene loco 😂', username: 'MiamiTraffic' },
    { text: 'Croquetas > todo lo demás', username: null },
    { text: 'Kristoff pa presidente 🗳️', username: 'VotaCubano' },
    { text: '100% Cubano sin filtro', username: 'RealTalk' },
    { text: 'El podcast está on fire 🎙️', username: null }
  ];

  interface NoteData { text: string; username: string | null; }

  async function fetchNotes(): Promise<NoteData[]> {
    if (!isSupabaseConfigured) return demoNotes;
    
    try {
      const res = await fetch(`${SUPABASE_URL}/rest/v1/notes?select=text,username&order=created_at.desc&limit=30`, {
        headers: {
          'apikey': SUPABASE_ANON_KEY,
          'Authorization': `Bearer ${SUPABASE_ANON_KEY}`
        }
      });
      const data = await res.json();
      if (Array.isArray(data) && data.length > 0) {
        return data.map((n: any) => ({ text: n.text, username: n.username || null }));
      }
    } catch(e) { /* fallback */ }
    return demoNotes;
  }

  async function submitNote(text: string, username: string | null) {
    if (!isSupabaseConfigured) return true;
    
    try {
      const body: any = { text };
      if (username) body.username = username;
      
      const res = await fetch(`${SUPABASE_URL}/rest/v1/notes`, {
        method: 'POST',
        headers: {
          'apikey': SUPABASE_ANON_KEY,
          'Authorization': `Bearer ${SUPABASE_ANON_KEY}`,
          'Content-Type': 'application/json',
          'Prefer': 'return=minimal'
        },
        body: JSON.stringify(body)
      });
      return res.ok;
    } catch(e) {
      return false;
    }
  }

  function createFloatingNote(noteData: NoteData, container: HTMLElement) {
    const note = document.createElement('div');
    note.className = 'absolute pointer-events-none select-none';
    
    // Build styled content
    if (noteData.username) {
      note.innerHTML = `<span style="color:rgba(255,214,0,0.4);font-weight:700;">@${noteData.username}</span> <span style="color:rgba(255,255,255,0.25);">${noteData.text}</span>`;
    } else {
      note.innerHTML = `<span style="color:rgba(255,255,255,0.2);">${noteData.text}</span>`;
    }
    
    note.style.fontFamily = 'Poppins, sans-serif';
    note.style.fontSize = `${0.75 + Math.random() * 0.35}rem`;
    note.style.whiteSpace = 'nowrap';
    note.style.padding = '4px 12px';
    note.style.borderRadius = '999px';
    note.style.background = 'rgba(255,255,255,0.03)';
    note.style.backdropFilter = 'blur(2px)';
    note.style.border = '1px solid rgba(255,255,255,0.05)';

    // Position on edges only (avoid center where content is)
    const edge = Math.floor(Math.random() * 4);
    if (edge === 0) { // top area
      note.style.top = `${5 + Math.random() * 15}%`;
      note.style.left = `${Math.random() * 70 + 5}%`;
    } else if (edge === 1) { // bottom area
      note.style.top = `${75 + Math.random() * 20}%`;
      note.style.left = `${Math.random() * 70 + 5}%`;
    } else if (edge === 2) { // left edge
      note.style.top = `${20 + Math.random() * 55}%`;
      note.style.left = `${Math.random() * 15}%`;
    } else { // right edge
      note.style.top = `${20 + Math.random() * 55}%`;
      note.style.right = `${Math.random() * 15}%`;
    }

    const duration = 20 + Math.random() * 20;
    const delay = Math.random() * 8;
    const rotate = (Math.random() - 0.5) * 12;
    note.style.transform = `rotate(${rotate}deg)`;
    note.style.animation = `floatNote ${duration}s ease-in-out ${delay}s infinite`;
    
    container.appendChild(note);
  }

  async function initNotes() {
    const container = document.getElementById('floating-notes');
    if (!container) return;
    
    const notes = await fetchNotes();
    notes.forEach(n => createFloatingNote(n, container));
  }

  // Form submission
  const form = document.getElementById('note-form') as HTMLFormElement;
  const input = document.getElementById('note-input') as HTMLInputElement;
  const usernameInput = document.getElementById('note-username') as HTMLInputElement;
  
  if (form && input) {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const text = input.value.trim();
      if (!text || text.length < 2) return;
      
      const username = usernameInput?.value.trim() || null;
      
      input.disabled = true;
      if (usernameInput) usernameInput.disabled = true;
      const btn = form.querySelector('button');
      if (btn) btn.textContent = '...';

      const ok = await submitNote(text, username);
      
      const container = document.getElementById('floating-notes');
      if (container) {
        createFloatingNote({ text, username }, container);
      }
      
      input.value = '';
      input.disabled = false;
      if (usernameInput) usernameInput.disabled = false;
      if (btn) btn.textContent = ok ? '✓ Enviado' : 'Enviar';
      setTimeout(() => { if (btn) btn.textContent = 'Enviar'; }, 2000);
    });
  }

  initNotes();
</script>

<style>
  @keyframes slideUp {
    from { transform: translateY(100px); opacity: 0; }
    to { transform: translateY(0); opacity: 1; }
  }
  @keyframes floatNote {
    0%, 100% { transform: translateY(0) translateX(0); opacity: 0.7; }
    15% { opacity: 1; }
    25% { transform: translateY(-12px) translateX(8px); }
    50% { transform: translateY(6px) translateX(-6px); opacity: 0.9; }
    75% { transform: translateY(-8px) translateX(12px); }
    85% { opacity: 1; }
  }
</style>
