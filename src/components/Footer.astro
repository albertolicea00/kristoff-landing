---
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<footer class="bg-secondary text-white py-12 border-t-8 border-primary">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-12 text-center md:text-left">
      <!-- Info -->
      <div class="flex flex-col items-center md:items-start space-y-4">
        <span class="font-heading text-5xl text-primary tracking-widest">KRIOLLO</span>
        <p class="font-body text-gray-400 max-w-xs">{t('hero.subtitle')}</p>
      </div>

      <!-- Social Links -->
      <div class="flex flex-col items-center md:items-start space-y-4">
        <h3 class="font-heading text-2xl uppercase tracking-widest text-accent">Socials</h3>
        <div class="flex space-x-5">
          <a href="https://www.youtube.com/@Kristoff9" target="_blank" rel="noopener noreferrer" class="text-gray-400 hover:text-primary transition-colors">
            <svg class="w-7 h-7" fill="currentColor" viewBox="0 0 24 24"><path fill-rule="evenodd" d="M19.812 5.418c.861.23 1.538.907 1.768 1.768C21.998 8.746 22 12 22 12s0 3.255-.418 4.814a2.504 2.504 0 0 1-1.768 1.768c-1.56.419-7.814.419-7.814.419s-6.255 0-7.814-.419a2.505 2.505 0 0 1-1.768-1.768C2 15.255 2 12 2 12s0-3.255.417-4.814a2.507 2.507 0 0 1 1.768-1.768C5.744 5 11.998 5 11.998 5s6.255 0 7.814.418ZM15.194 12 10 15V9l5.194 3Z" clip-rule="evenodd" /></svg>
          </a>
          <a href="https://www.tiktok.com/@kristoff_y" target="_blank" rel="noopener noreferrer" class="text-gray-400 hover:text-white transition-colors">
            <svg class="w-7 h-7" fill="currentColor" viewBox="0 0 448 512"><path d="M448,209.91a210.06,210.06,0,0,1-122.77-39.25V349.38A162.55,162.55,0,1,1,185,188.31V278.2a74.62,74.62,0,1,0,52.23,71.18V0l88,0a121.18,121.18,0,0,0,1.86,22.17h0A122.18,122.18,0,0,0,381,102.39a121.43,121.43,0,0,0,67,20.14Z"/></svg>
          </a>
          <a href="https://www.instagram.com/kristoff_kriollo/" target="_blank" rel="noopener noreferrer" class="text-gray-400 hover:text-pink-500 transition-colors">
            <svg class="w-7 h-7" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line></svg>
          </a>
          <a href="https://www.twitch.tv/kristoff_kriollo" target="_blank" rel="noopener noreferrer" class="text-gray-400 hover:text-purple-500 transition-colors">
            <svg class="w-7 h-7" fill="currentColor" viewBox="0 0 24 24"><path d="M11.571 4.714h1.715v5.143H11.57zm4.715 0H18v5.143h-1.714zM6 0L1.714 4.286v15.428h5.143V24l4.286-4.286h3.428L22.286 12V0zm14.571 11.143l-3.428 3.428h-3.429l-3 3v-3H6.857V1.714h13.714Z"/></svg>
          </a>
        </div>
      </div>

      <!-- Newsletter & Developers -->
      <div class="flex flex-col items-center md:items-start space-y-4">
        <h3 class="font-heading text-2xl uppercase tracking-widest text-accent">{t('footer.newsletter')}</h3>
        <form class="flex w-full space-x-2">
          <input disabled type="email" placeholder={t('footer.newsletter.placeholder')} class="w-full px-4 py-3 rounded bg-gray-800 text-gray-500 border border-gray-700 cursor-not-allowed font-body text-sm">
          <button disabled type="submit" class="bg-gray-700 text-gray-400 px-5 py-3 rounded font-heading text-lg uppercase tracking-wider cursor-not-allowed shadow-none">
            {t('footer.newsletter.submit')}
          </button>
        </form>
        
        <!-- For Developers (Mini) -->
        <div class="pt-4 mt-2 border-t border-gray-800 w-full text-left flex flex-col sm:flex-row items-center justify-between gap-4">
          <p class="font-body text-gray-400 text-xs">
            ¿Eres developer? Únete al equipo y crea herramientas de la comunidad.
          </p>
          <a href="/developers" class="bg-gray-800 hover:bg-gray-700 text-gray-300 border border-gray-700 font-heading text-[10px] uppercase tracking-wider px-3 py-1.5 rounded transition-colors whitespace-nowrap">
            Más info
          </a>
        </div>
      </div>
    </div>
    
    <div class="mt-12 pt-8 border-t border-gray-800 flex flex-col md:flex-row justify-between items-center text-gray-500 font-body text-sm gap-4">
      <p>&copy; {new Date().getFullYear()} Kristoff Kriollo. {t('footer.rights')}</p>
      <div class="flex gap-6">
        <a href="/developers" class="hover:text-gray-300 transition-colors">Developers</a>
        <a href="/projects" class="hover:text-gray-300 transition-colors">Proyectos</a>
      </div>
    </div>
  </div>
</footer>
