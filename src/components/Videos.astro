---
import { getLangFromUrl, useTranslations } from '../i18n/utils';
import { fetchLatestVideos } from '../utils/youtube';
import { getTwitchStatus } from '../utils/social';

interface VideoData {
  id: string;
  title: string;
  time: string;
  thumbnail: string;
  link: string;
  channel: string;
  isUpcoming?: boolean;
  isMembersOnly?: boolean;
  premiereTime?: string;
}

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const youtubeApiKey = import.meta.env.PUBLIC_YOUTUBE_API_KEY?.trim() || '';
const useRealtimeVideos = youtubeApiKey.length > 0;
const loadingCards = Array.from({ length: 3 });

let mainVideos: VideoData[] = [];
let vodVideos: VideoData[] = [];
let podcastVideos: VideoData[] = [];
let isTwitchLive = false;

if (!useRealtimeVideos) {
  const latestVideos = await fetchLatestVideos();
  mainVideos = latestVideos.mainVideos;
  vodVideos = latestVideos.vodVideos;
  podcastVideos = latestVideos.podcastVideos;
  isTwitchLive = Boolean(await getTwitchStatus());
}

const copy = lang === 'es'
  ? {
      liveTitle: 'KRISTOFF ESTA EN DIRECTO AHORA',
      liveSubtitle: "Entra pa' que goces con la locura en Twitch",
      viewLive: 'Ver Directo',
      mainChannelSubtitle: '@Kristoff9 — Canal principal',
      mainChannelLink: 'Ver canal',
      vodChannelSubtitle: '@Kristoffvod — Streams y momentos completos',
      podcastBadge: 'Ultimo del Podcast',
      podcastDescription: 'No te pierdas el episodio mas reciente de "Esto No Es Un Podcast Miami". Kristoff y el equipo debatiendo lo que nadie se atreve.',
      watchEpisode: 'Ver Episodio',
      allEpisodes: 'Todos los episodios',
      errorText: 'No se pudieron cargar los videos ahora mismo.',
      emptyText: 'No hay videos disponibles ahora mismo.',
      mainBadge: 'Kristoff',
      vodBadge: 'TV',
    }
  : {
      liveTitle: 'KRISTOFF IS LIVE RIGHT NOW',
      liveSubtitle: 'Jump into the chaos on Twitch.',
      viewLive: 'Watch Live',
      mainChannelSubtitle: '@Kristoff9 — Main channel',
      mainChannelLink: 'View channel',
      vodChannelSubtitle: '@Kristoffvod — Full streams and highlights',
      podcastBadge: 'Latest Podcast Episode',
      podcastDescription: 'Catch the newest episode of "Esto No Es Un Podcast Miami". Kristoff and the crew talking about what nobody else dares to touch.',
      watchEpisode: 'Watch Episode',
      allEpisodes: 'All Episodes',
      errorText: 'Videos could not be loaded right now.',
      emptyText: 'No videos are available right now.',
      mainBadge: 'Kristoff',
      vodBadge: 'TV',
    };
---

<section
  id="videos"
  class="py-24 bg-background"
  data-videos-root
  data-youtube-api-key={youtubeApiKey}
  data-lang={lang}
  data-error-text={copy.errorText}
  data-empty-text={copy.emptyText}
  data-main-badge={copy.mainBadge}
  data-vod-badge={copy.vodBadge}
  data-podcast-badge={copy.podcastBadge}
  data-podcast-description={copy.podcastDescription}
  data-watch-episode={copy.watchEpisode}
  data-all-episodes={copy.allEpisodes}
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div
      id="twitch-live-banner"
      class:list={[
        'mb-12 bg-purple-900 border-l-8 border-purple-500 rounded-lg p-6 shadow-xl flex flex-col md:flex-row justify-between items-center transform hover:scale-[1.01] transition-transform',
        (useRealtimeVideos || !isTwitchLive) && 'hidden'
      ]}
    >
      <div class="flex items-center space-x-4 mb-4 md:mb-0">
        <div class="relative">
          <div class="w-4 h-4 bg-red-500 rounded-full animate-ping absolute"></div>
          <div class="w-4 h-4 bg-red-500 rounded-full relative z-10"></div>
        </div>
        <div>
          <h3 class="text-white font-heading text-2xl tracking-widest uppercase m-0">{copy.liveTitle}</h3>
          <p class="text-purple-200 font-body m-0">{copy.liveSubtitle}</p>
        </div>
      </div>
      <a href="https://www.twitch.tv/kristoff_kriollo" target="_blank" rel="noopener noreferrer" class="bg-purple-600 hover:bg-purple-500 text-white font-heading text-xl px-8 py-3 rounded uppercase tracking-wider shadow-lg active:scale-95 transition-all w-full md:w-auto text-center">
        {copy.viewLive}
      </a>
    </div>

    <div class="flex justify-between items-end mb-12">
      <div>
        <h2 class="section-title mb-0 text-primary">{t('videos.title')}</h2>
        <p class="font-body text-gray-400 text-sm mt-1">{copy.mainChannelSubtitle}</p>
      </div>
      <a href="https://www.youtube.com/@Kristoff9" target="_blank" rel="noopener noreferrer" class="hidden md:flex items-center text-secondary font-heading text-xl uppercase tracking-wider hover:text-primary transition-colors hover:translate-x-2 transform duration-300">
        {copy.mainChannelLink} <span class="ml-2 text-2xl">→</span>
      </a>
    </div>

    <div id="main-videos-grid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 mb-20">
      {useRealtimeVideos ? loadingCards.map(() => (
        <article class="bg-white rounded-xl shadow-md border border-gray-100 overflow-hidden animate-pulse" aria-hidden="true">
          <div class="aspect-video bg-gray-200 border-b-4 border-primary"></div>
          <div class="p-5">
            <div class="h-4 bg-gray-200 rounded w-full mb-3"></div>
            <div class="h-4 bg-gray-100 rounded w-4/5 mb-4"></div>
            <div class="flex gap-2">
              <div class="h-5 w-20 rounded bg-red-100"></div>
              <div class="h-5 w-24 rounded bg-gray-100"></div>
            </div>
          </div>
        </article>
      )) : (mainVideos || []).map((video) => (
        <a href={video.link} target="_blank" rel="noopener noreferrer" class="group block cursor-pointer bg-white rounded-xl shadow-md hover:shadow-2xl transition-all duration-300 transform hover:-translate-y-2 border border-gray-100 overflow-hidden">
          <div class="relative w-full aspect-video bg-gray-900 border-b-4 border-primary">
            <img src={video.thumbnail} alt={video.title} class="w-full h-full object-cover opacity-90 group-hover:opacity-100 transition-opacity" loading="lazy" />
            <div class="absolute inset-0 bg-gradient-to-t from-secondary/80 to-transparent flex items-center justify-center transition-all opacity-0 group-hover:opacity-100">
              <div class="w-16 h-16 bg-primary rounded-full flex items-center justify-center shadow-[0_0_20px_rgba(255,59,59,0.6)]">
                <svg class="w-8 h-8 text-white ml-1" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM9.555 7.168A1 1 0 008 8v4a1 1 0 001.555.832l3-2a1 1 0 000-1.664l-3-2z" clip-rule="evenodd"></path></svg>
              </div>
            </div>
          </div>
          <div class="p-5">
            <h3 class="font-body font-bold text-base text-secondary line-clamp-2 leading-tight mb-2 group-hover:text-primary transition-colors">
              {video.title}
            </h3>
            <div class="flex flex-wrap gap-2">
              <span class="flex items-center font-medium bg-red-50 text-primary px-2 py-0.5 rounded text-xs font-body w-fit">
                <svg class="w-3.5 h-3.5 mr-1" fill="currentColor" viewBox="0 0 24 24"><path d="M19.615 3.184c-3.604-.246-11.631-.245-15.23 0-3.897.266-4.356 2.62-4.385 8.816.029 6.185.484 8.549 4.385 8.816 3.6.245 11.626.246 15.23 0 3.897-.266 4.356-2.62 4.385-8.816-.029-6.185-.484-8.549-4.385-8.816zm-10.615 12.816v-8l8 3.993-8 4.007z"/></svg>
                {copy.mainBadge}
              </span>
              {video.isUpcoming && (
                <span class="bg-blue-600 text-white px-2 py-0.5 rounded text-[10px] font-bold uppercase tracking-wider animate-pulse">
                  Próximamente: {video.premiereTime}
                </span>
              )}
              {video.isMembersOnly && (
                <span class="bg-green-600 text-white px-2 py-0.5 rounded text-[10px] font-bold uppercase tracking-wider">
                  Solo Miembros
                </span>
              )}
            </div>
          </div>
        </a>
      ))}
    </div>

    <div id="vod-section" class:list={[!useRealtimeVideos && vodVideos.length === 0 && 'hidden']}>
      <div class="flex justify-between items-end mb-12 border-t-2 border-gray-100 pt-16">
        <div>
          <h2 class="section-title mb-0 text-secondary">Kristoff <span class="text-accent">TV</span></h2>
          <p class="font-body text-gray-400 text-sm mt-1">{copy.vodChannelSubtitle}</p>
        </div>
        <a href="https://www.youtube.com/@Kristoffvod" target="_blank" rel="noopener noreferrer" class="hidden md:flex items-center text-secondary font-heading text-xl uppercase tracking-wider hover:text-primary transition-colors hover:translate-x-2 transform duration-300">
          {copy.mainChannelLink} <span class="ml-2 text-2xl">→</span>
        </a>
      </div>

      <div id="vod-videos-grid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 mb-20">
        {useRealtimeVideos ? loadingCards.map(() => (
          <article class="bg-white rounded-xl shadow-md border border-gray-100 overflow-hidden animate-pulse" aria-hidden="true">
            <div class="aspect-video bg-gray-200 border-b-4 border-accent"></div>
            <div class="p-5">
              <div class="h-4 bg-gray-200 rounded w-full mb-3"></div>
              <div class="h-4 bg-gray-100 rounded w-4/5 mb-4"></div>
              <div class="flex gap-2">
                <div class="h-5 w-16 rounded bg-yellow-100"></div>
                <div class="h-5 w-24 rounded bg-gray-100"></div>
              </div>
            </div>
          </article>
        )) : vodVideos.map((video) => (
          <a href={video.link} target="_blank" rel="noopener noreferrer" class="group block cursor-pointer bg-white rounded-xl shadow-md hover:shadow-2xl transition-all duration-300 transform hover:-translate-y-2 border border-gray-100 overflow-hidden">
            <div class="relative w-full aspect-video bg-gray-900 border-b-4 border-accent">
              <img src={video.thumbnail} alt={video.title} class="w-full h-full object-cover opacity-90 group-hover:opacity-100 transition-opacity" loading="lazy" />
              <div class="absolute inset-0 bg-gradient-to-t from-secondary/80 to-transparent flex items-center justify-center transition-all opacity-0 group-hover:opacity-100">
                <div class="w-16 h-16 bg-accent rounded-full flex items-center justify-center shadow-[0_0_20px_rgba(255,214,0,0.6)]">
                  <svg class="w-8 h-8 text-secondary ml-1" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM9.555 7.168A1 1 0 008 8v4a1 1 0 001.555.832l3-2a1 1 0 000-1.664l-3-2z" clip-rule="evenodd"></path></svg>
                </div>
              </div>
            </div>
            <div class="p-5">
              <h3 class="font-body font-bold text-base text-secondary line-clamp-2 leading-tight mb-2 group-hover:text-accent transition-colors">
                {video.title}
              </h3>
              <div class="flex flex-wrap gap-2">
                <span class="flex items-center font-medium bg-yellow-50 text-yellow-700 px-2 py-0.5 rounded text-xs font-body w-fit">
                  {copy.vodBadge}
                </span>
                {video.isUpcoming && (
                  <span class="bg-blue-600 text-white px-2 py-0.5 rounded text-[10px] font-bold uppercase tracking-wider animate-pulse">
                    {video.premiereTime}
                  </span>
                )}
                {video.isMembersOnly && (
                  <span class="bg-green-600 text-white px-2 py-0.5 rounded text-[10px] font-bold uppercase tracking-wider">
                    Solo Miembros
                  </span>
                )}
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>

    <div id="podcast-section" class:list={['mt-20 border-t border-gray-100 pt-12', !useRealtimeVideos && podcastVideos.length === 0 && 'hidden']}>
      <div id="podcast-card">
        {useRealtimeVideos ? (
          <article class="bg-secondary/5 rounded-3xl p-6 md:p-10 border border-gray-100 animate-pulse" aria-hidden="true">
            <div class="flex flex-col md:flex-row gap-8 items-center">
              <div class="w-full md:w-2/5 aspect-video rounded-2xl bg-gray-200"></div>
              <div class="flex-1 w-full">
                <div class="h-6 w-40 rounded bg-secondary/10 mb-6"></div>
                <div class="h-7 w-full rounded bg-gray-200 mb-4"></div>
                <div class="h-7 w-3/4 rounded bg-gray-100 mb-6"></div>
                <div class="h-4 w-full rounded bg-gray-100 mb-3 hidden md:block"></div>
                <div class="h-4 w-5/6 rounded bg-gray-100 mb-6 hidden md:block"></div>
                <div class="flex flex-col sm:flex-row gap-4">
                  <div class="h-12 w-40 rounded-xl bg-secondary/20"></div>
                  <div class="h-12 w-40 rounded-xl bg-gray-100"></div>
                </div>
              </div>
            </div>
          </article>
        ) : podcastVideos[0] ? (
          <div class="bg-secondary/5 rounded-3xl p-6 md:p-10 flex flex-col md:flex-row items-center gap-8 border border-gray-100 hover:shadow-xl transition-all duration-500">
            <div class="w-full md:w-2/5 aspect-video rounded-2xl overflow-hidden shadow-2xl flex-shrink-0 group relative">
              <a href={podcastVideos[0].link} target="_blank" rel="noopener noreferrer" class="block w-full h-full">
                <img src={podcastVideos[0].thumbnail} alt={podcastVideos[0].title} class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700" />
                <div class="absolute inset-0 bg-secondary/20 group-hover:bg-secondary/40 flex items-center justify-center transition-colors">
                  <div class="w-14 h-14 bg-white/90 backdrop-blur-sm rounded-full flex items-center justify-center shadow-lg group-hover:scale-110 transition-transform">
                    <svg class="w-7 h-7 text-secondary ml-1" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM9.555 7.168A1 1 0 008 8v4a1 1 0 001.555.832l3-2a1 1 0 000-1.664l-3-2z" clip-rule="evenodd"></path></svg>
                  </div>
                </div>
              </a>
            </div>
            <div class="flex-1 text-center md:text-left">
              <div class="inline-flex items-center gap-2 mb-4 bg-secondary/10 px-3 py-1 rounded-full border border-secondary/10">
                <span class="w-2 h-2 bg-secondary rounded-full animate-pulse"></span>
                <span class="text-secondary text-[10px] md:text-xs font-heading font-bold uppercase tracking-widest">
                  {podcastVideos[0].isUpcoming ? 'Próximo Estreno' : podcastVideos[0].isMembersOnly ? 'Contenido Exclusivo' : copy.podcastBadge}
                </span>
              </div>
              {podcastVideos[0].isUpcoming && (
                <div class="mb-4 text-secondary/60 text-xs font-heading font-bold uppercase tracking-widest">
                  Se estrena: {podcastVideos[0].premiereTime}
                </div>
              )}
              <h3 class="text-2xl md:text-3xl font-heading font-bold text-secondary mb-4 leading-tight">
                {podcastVideos[0].title}
              </h3>
              <p class="font-body text-gray-500 text-sm mb-6 max-w-lg hidden md:block">
                {copy.podcastDescription}
              </p>
              <div class="flex flex-col sm:flex-row items-center gap-5">
                <a href={podcastVideos[0].link} target="_blank" rel="noopener noreferrer" class="w-full sm:w-auto bg-secondary hover:bg-black text-white px-8 py-3.5 rounded-xl font-heading text-sm uppercase tracking-wider shadow-lg hover:shadow-secondary/20 transition-all active:scale-95">
                  {copy.watchEpisode}
                </a>
                <a href="https://www.youtube.com/@EstoNoEsUnPodcastMiami" target="_blank" rel="noopener noreferrer" class="text-secondary/60 hover:text-secondary text-xs font-heading underline underline-offset-8 uppercase tracking-widest transition-colors font-bold">
                  {copy.allEpisodes}
                </a>
              </div>
            </div>
          </div>
        ) : null}
      </div>
    </div>
  </div>
</section>

<script>
  import { initVideosSection } from '../scripts/videos';

  initVideosSection();
</script>
