---
import { getLangFromUrl, useTranslations } from '../i18n/utils';
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
	title: string;
}

const { title } = Astro.props;
const lang = getLangFromUrl(Astro.url);
const currentUrl = Astro.url.pathname;
const isHome = currentUrl === '/' || currentUrl === '/en' || currentUrl === '/en/';

// Import Fonts from Google Fonts
const fontsUrl = "https://fonts.googleapis.com/css2?family=Anton&family=Bebas+Neue&family=Inter:wght@400;600;700&family=Poppins:wght@400;600;700;800&display=swap";
---

<!doctype html>
<html lang={lang} class="scroll-smooth">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content="Kristoff Kriollo - Creador de contenido cubano" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" type="image/png" href="https://yt3.ggpht.com/_nwkuUvKJT-ztrUNH1bymp7trvZfDXp07UVV7NJNv-Zfws0Wpnlla9nExFRhYSVNAMeKxt9AHA=s88-c-k-c0x00ffffff-no-rj" />
		<link rel="apple-touch-icon" href="https://yt3.ggpht.com/_nwkuUvKJT-ztrUNH1bymp7trvZfDXp07UVV7NJNv-Zfws0Wpnlla9nExFRhYSVNAMeKxt9AHA=s240-c-k-c0x00ffffff-no-rj" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		
		<!-- Preconnect and Load Fonts -->
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href={fontsUrl} rel="stylesheet">
	</head>
	<body class="bg-background text-secondary antialiased overflow-x-hidden selection:bg-primary selection:text-white">
		<Header />
		<main>
			<slot />
		</main>
		<Footer />
	</body>
</html>
